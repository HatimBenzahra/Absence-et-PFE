#!/bin/sh
# Maven Wrapper script

# Resolve script directory
SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)

# Find java
if [ -n "$JAVA_HOME" ]; then
    JAVA_CMD="$JAVA_HOME/bin/java"
else
    JAVA_CMD="java"
fi

# Run maven wrapper
exec "$JAVA_CMD" \
    -Dmaven.multiModuleProjectDirectory="$SCRIPT_DIR" \
    -jar "$SCRIPT_DIR/.mvn/wrapper/maven-wrapper.jar" "$@"
